# ── API Backend ─────────────────────────────────────────────
# URL base del backend Laravel (sin trailing slash).
# Puede incluir /api o no; el cliente lo normaliza automaticamente.
# Dev:  http://localhost:8000  o  http://localhost:8000/api
# Prod: https://api.tudominio.com  o  https://api.tudominio.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── App ─────────────────────────────────────────────────────
# Nombre del sitio (usado en metadatos, Navbar, Footer)
NEXT_PUBLIC_APP_NAME="Portafolio Daniel Sierra"

# URL pública del frontend (sin trailing slash)
# Usada para metadatos OpenGraph y sitemap
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Escalabilidad: Analytics ─────────────────────────────────
# Para añadir métricas de visitas, descomentar e instalar el paquete:
#
# Google Analytics 4:
#   NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
#
# Plausible (privacy-first, recomendado):
#   NEXT_PUBLIC_PLAUSIBLE_DOMAIN=tudominio.com

# ── Escalabilidad: App móvil / PWA ───────────────────────────
# Si conviertes el frontend en una PWA instalable:
#   NEXT_PUBLIC_APP_THEME_COLOR=#4f46e5
# Añadir manifest.json en /public y configurar next-pwa.

# ── Escalabilidad: i18n ──────────────────────────────────────
# Para soporte multiidioma (es/en):
#   NEXT_PUBLIC_DEFAULT_LOCALE=es
# Usar next-intl o next-i18next.
