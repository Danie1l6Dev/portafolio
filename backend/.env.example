APP_NAME="Portafolio Daniel Sierra"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logging ─────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Base de datos (MySQL) ────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=portfolio
DB_USERNAME=root
DB_PASSWORD=

# ── Sesión ──────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Broadcasting / Colas / Cache ─────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Redis (opcional) ─────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Correo ──────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@portafolio.test"
MAIL_FROM_NAME="${APP_NAME}"

# ── CORS – origen permitido del frontend ─────────────────────
FRONTEND_URL=http://localhost:3000

# ── Sanctum ─────────────────────────────────────────────────
# SANCTUM_STATEFUL_DOMAINS no se usa con autenticación Bearer token.
# Se mantiene por compatibilidad futura con SPA cookie-based.
SANCTUM_STATEFUL_DOMAINS=localhost:3000

# Expiración de tokens en minutos. null = sin expiración.
# Para apps móviles se recomienda 43200 (30 días).
# Para panel admin se recomienda 1440 (24 horas).
SANCTUM_TOKEN_EXPIRATION=null

# ── Admin (credenciales del seeder — cambiar antes de producción) ──
ADMIN_NAME="Administrador"
ADMIN_EMAIL=admin@portafolio.test
ADMIN_PASSWORD=password

# ── Escalabilidad: múltiples usuarios ────────────────────────
# Roles disponibles: admin, editor
# admin  → acceso total (CRUD + gestión de usuarios)
# editor → solo gestión de contenido (proyectos, skills, experiencias)
# Para ampliar roles con permisos granulares: composer require spatie/laravel-permission

# ── Escalabilidad: Blog ───────────────────────────────────────
# Para añadir blog ejecutar:
#   php artisan make:model Post -mrc
# El modelo seguirá el mismo patrón que Project (HasSlug, status, media).
# Registro de rutas en routes/api.php bajo /v1/posts y /v1/admin/posts.

# ── Escalabilidad: App móvil ─────────────────────────────────
# La API REST ya es consumible por React Native, Flutter, etc.
# El Bearer token funciona igual en cualquier cliente HTTP.
# Para tokens de app móvil con larga duración:
#   SANCTUM_TOKEN_EXPIRATION=43200
# Considerar refresh tokens con spatie/laravel-sanctum-refresh-tokens.
