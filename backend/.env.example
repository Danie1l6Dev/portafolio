APP_NAME="Portafolio Daniel Sierra"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=portfolio
DB_USERNAME=root
DB_PASSWORD=

# Session / Sanctum SPA
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Produccion: usa dominio compartido entre frontend y backend (ej: .midominio.com)
# Local: usa null
SESSION_DOMAIN=.tudominio.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=none

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@portafolio.test"
MAIL_FROM_NAME="${APP_NAME}"

# CORS
FRONTEND_URL=http://localhost:3000

# Sanctum stateful domains (frontend hosts)
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000,portafoliodaniel-two.vercel.app

# Seeder admin
ADMIN_NAME="Administrador"
ADMIN_EMAIL=admin@portafolio.test
ADMIN_PASSWORD=password
