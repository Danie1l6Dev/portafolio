# ============================================================
# Monorepo – portafolio
# ============================================================

# ── OS ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editores / IDEs ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs globales ───────────────────────────────────────────
*.log
logs/

# ── Variables de entorno (nunca al repo) ────────────────────
.env
.env.local
.env.*.local

# ── Backend Laravel ─────────────────────────────────────────
/backend/.env
/backend/.env.backup
/backend/.env.production
/backend/vendor/
/backend/node_modules/
/backend/public/build/
/backend/public/hot/
/backend/public/storage/
/backend/storage/*.key
/backend/storage/pail/
/backend/.phpunit.cache/
/backend/.phpunit.result.cache
/backend/auth.json
/backend/_ide_helper.php

# ── Frontend Next.js ────────────────────────────────────────
/frontend/node_modules/
/frontend/.next/
/frontend/out/
/frontend/build/
/frontend/.vercel/
/frontend/coverage/
/frontend/*.tsbuildinfo
/frontend/next-env.d.ts

# ── Git lock residual ────────────────────────────────────────
*.lock.bak
